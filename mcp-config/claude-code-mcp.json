{
  "mcpServers": {
    "frida": {
      "command": "frida-mcp"
    },
    "jadx": {
      "command": "python3",
      "args": [
        "/absolute/path/to/deps/jadx-mcp-server/jadx_mcp_server.py"
      ]
    },
    "apktool": {
      "command": "uv",
      "args": [
        "--directory",
        "/absolute/path/to/deps/apktool-mcp-server",
        "run",
        "apktool_mcp_server.py"
      ]
    }
  }
}
